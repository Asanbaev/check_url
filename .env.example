NODE_ENV=development
# HTTP: сводка статусов по запросу из telegram_alert (POST /v1/status-summary, x-app-token = TELEGRAM_ALERT_TOKEN)
PORT=1342
# Режим входа запросов status-summary:
# http - принимать POST /v1/status-summary
# db   - читать запросы из таблицы inbound_transport_request в БД telegram_alert_api
STATUS_SUMMARY_INGRESS_MODE=http
STATUS_SUMMARY_DB_POLL_MS=10000
STATUS_SUMMARY_DB_POLL_BATCH_SIZE=20
STATUS_SUMMARY_DB_MAX_ATTEMPTS=10
STATUS_SUMMARY_TRANSPORT_APP_CODE=check_url
CHECK_INTERVAL_MS=20000
QUIET_HOURS_START=22
QUIET_HOURS_END=7
NIGHT_INTERVAL_MULTIPLIER=60
MSG_MIN_HOURS=3
MONITOR_MODE=general
# Браузер для подключения через CDP: chrome | firefox | opera
BROWSER_KIND=chrome
# Chrome (по умолчанию): http://127.0.0.1:9222
# Firefox: http://127.0.0.1:9223
# Opera: http://127.0.0.1:9224
BROWSER_PROTOCOL_TIMEOUT_MS=60000
BROWSER_PAGE_GOTO_TIMEOUT_MS=20000
BROWSER_URL=http://127.0.0.1:9222
# Известный «максимальный» номер события Timepad; на странице берётся ссылка с id строго выше (макс. из подходящих)
VGIK_MAI_MAX_TIMEPAD_EVENT_ID=3931025
# Режим VGIK Май: 1=поиск маркера «мая», 2=уведомление о новых ссылках Timepad, 3=как 2 + вкладки на новые события и сценарий формы, 4=как 2 + axios POST (два URL) в фоне
VGIK_MAI_MODE=1
# Интервал между попытками HTML-submit (submitting) и между тиками mode4 (мс); при отсутствии — VGIK_MODE3_POLL_MS или 20000
VGIK_SUBMIT_RETRY_MS=20000
# Режим 4: URL двух POST (при отсутствии используются VGIK_MODE3_STEP1_URL / VGIK_MODE3_STEP2_URL)
# VGIK_MODE4_STEP1_URL=https://priemvgik.timepad.ru/event/widget_register/...
# VGIK_MODE4_STEP2_URL=https://priemvgik.timepad.ru/event/widget_register/...
# После заполнения анкеты на динамическом Timepad: true — авто HTML-submit для мастерских Мерзликин/Фёдоров (один раз каждая)
VGIK_HTML_SUBMIT_ENABLED=false
# Ожидание iframe виджета Timepad во вкладке VGIK Mai (по умолчанию как BROWSER_PAGE_GOTO_TIMEOUT_MS)
VGIK_MAI_TIMEPAD_IFRAME_WAIT_MS=30000
GITIS_MODAL_WAIT_MS=1500
GITIS_MODAL_RELOAD_ATTEMPTS=2
# Пауза стабилизации DOM после появления модалки .one-course перед анализом auth/free_dates
GITIS_MODAL_STABILIZE_MS=500
# true — после выбора даты выбрать первое время и нажать "Записаться"; false — только детект/снимки без сабмита
GITIS_SUBMIT_ENABLED=false
# Порог сабмита для GITIS: сабмит разрешён только если выбранная дата строго раньше этого значения (YYYY-MM-DD)
GITIS_SUBMIT_BEFORE_DATE=2026-06-01
STATUS_DB_LOG_INTERVAL_MIN=5
# 1 или true — сохранять полный HTML страницы в outputs/{timestamp}_key_false_{target}.html при key_false (как и остальные снимки по тому же шаблону)
SAVE_PAGE_HTML=0
REQUEST_STUCK_TIMEOUT_MS=60000
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=check_url
DB_USER=alerts_user
DB_PASSWORD=alerts_password
# Второе подключение к БД telegram_alert_api для чтения входящих transport-запросов (режим STATUS_SUMMARY_INGRESS_MODE=db)
TA_DB_HOST=127.0.0.1
TA_DB_PORT=3306
TA_DB_NAME=telegram_alert_api
TA_DB_USER=alerts_user
TA_DB_PASSWORD=alerts_password
TELEGRAM_ALERT_URL=http://127.0.0.1:1341/v1/queue/message
TELEGRAM_ALERT_TOKEN=change_me_token
TELEGRAM_ALERT_APP_CODE=check_url
TELEGRAM_ALERT_BOT_CODE=main_bot
# Все алерты → Vadim; дополнительно при статусе key_false → Sofa (если id отличается от Vadim)
TG_CHAT_ID_VADIM=
TG_CHAT_ID_SOFA=
