#!/usr/bin/env bash
set -euo pipefail

# Для snap-версии Firefox профиль должен быть в разрешённой зоне snap.
PROFILE_DIR="${HOME}/snap/firefox/common/check_url-firefox-profile-debug"
mkdir -p "${PROFILE_DIR}"
# На случай некорректного завершения прошлого процесса Firefox.
rm -f "${PROFILE_DIR}/parent.lock" "${PROFILE_DIR}/lock"

exec /usr/bin/firefox \
  --remote-debugging-port=9223 \
  --profile "${PROFILE_DIR}" \
  --new-instance \
  --new-window "about:blank" \
  --window-size 1920,1080 \
  --window-position 0,0 \
  --no-remote
