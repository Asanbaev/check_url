#!/usr/bin/env bash
set -euo pipefail

USER_DATA_DIR="${HOME}/.cache/check_url/opera-profile-debug"
mkdir -p "${USER_DATA_DIR}"

exec /usr/bin/opera \
  --remote-debugging-port=9224 \
  --user-data-dir="${USER_DATA_DIR}" \
  --new-window \
  --window-position=0,0 \
  --window-size=1920,1080 \
  --no-first-run \
  --no-default-browser-check
